{
  "name": "@rsbuild/plugin-assets-retry",
  "version": "2.0.1",
  "description": "An Rsbuild plugin to automatically resend requests when static assets fail to load.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rstackjs/rsbuild-plugin-assets-retry.git"
  },
  "homepage": "https://github.com/rstackjs/rsbuild-plugin-assets-retry#readme",
  "bugs": {
    "url": "https://github.com/rstackjs/rsbuild-plugin-assets-retry/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "lint": "rslint && prettier -c .",
    "lint:write": "rslint --fix && prettier -w .",
    "prepare": "simple-git-hooks",
    "test": "rstest",
    "bump": "pnpx bumpp"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:write"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.6.5",
    "@rstackjs/test-utils": "^0.2.0",
    "@rstest/core": "^0.11.1",
    "@rstest/playwright": "^0.11.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/serialize-javascript": "^5.0.4",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rsbuild-plugin-publint": "^1.0.0",
    "serialize-javascript": "^7.0.7",
    "simple-git-hooks": "^2.13.1",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.13.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
